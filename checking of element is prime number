from collections import Counter
import math

class Solution:
    def checkPrimeFrequency(self, nums):
        def is_prime(n):
            if n <= 1:
                return False
            if n <= 3:
                return True
            if n % 2 == 0 or n % 3 == 0:
                return False
            for i in range(5, int(math.sqrt(n)) + 1, 6):
                if n % i == 0 or n % (i + 2) == 0:
                    return False
            return True
        
        freq = Counter(nums)
        
        for count in freq.values():
            if is_prime(count):
                return True
        
        return False
