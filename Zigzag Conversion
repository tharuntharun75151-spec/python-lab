class Solution:
    def convert(self, s: str, numRows: int) -> str:
        if numRows == 1 or numRows >= len(s):
            return s
        
        rows = [''] * numRows
        going_down = True
        curr_row = 0
        
        for char in s:
            rows[curr_row] += char
            
           
            if curr_row == 0:
                going_down = True
            elif curr_row == numRows - 1:
                going_down = False
            
            curr_row += 1 if going_down else -1
        
        return ''.join(rows)
