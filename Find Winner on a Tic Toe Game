    print(f"Result: {sol.tictactoe(moves3)}")  # "Draw"
    
    print("\nTEST 4: Pending")
    moves4 = [[0,0],[1,1]]
    print(f"Result: {sol.tictactoe(moves4)}")  # "Pending"

