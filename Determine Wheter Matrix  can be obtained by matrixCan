class Solution:
    def findRotation(self, mat: List[List[int]], target: List[List[int]]) -> bool:
        def rotate(matrix):
            n = len(matrix)
            return [list(reversed(col)) for col in zip(*matrix)]
        
        current = [row[:] for row in mat]
        
        for _ in range(4):
            if current == target:
                return True
            current = rotate(current)
        
        return False
