class Solution:
    def floodFill(self, image: List[List[int]], sr: int, sc: int, color: int) -> List[List[int]]:
      
        if not image or not image[0]:
            return image
        
        m, n = len(image), len(image[0])
        original_color = image[sr][sc]
        
        # No change needed if already target color
        if original_color == color:
            return image
        
        # 4-directional neighbors (up, down, left, right)
        directions = [(-1, 0), (1, 0), (0, -1), (0, 1)]
        
        def dfs(i: int, j: int) -> None:
            """DFS helper: fill current cell and recurse to neighbors"""
            # Base case: out of bounds or wrong color or already filled
            if (i < 0 or i >= m or j < 0 or j >= n or 
                image[i][j] != original_color):
                return
            
            # Fill current cell
            image[i][j] = color
            
            # Recurse to 4 neighbors
            for di, dj in directions:
                ni, nj = i + di, j + dj
                dfs(ni, nj)
        
        # Start flood fill from (sr, sc)
        dfs(sr, sc)
        return image
