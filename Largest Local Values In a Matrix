class Solution:
    def largestLocal(self, grid: List[List[int]]) -> List[List[int]]:
        n = len(grid)
        m = n - 2
        
        result = [[0] * m for _ in range(m)]
        
        for i in range(m):
            for j in range(m):
                max_val = 0
                for x in range(3):
                    for y in range(3):
                        max_val = max(max_val, grid[i + x][j + y])
                result[i][j] = max_val
        
        return result
