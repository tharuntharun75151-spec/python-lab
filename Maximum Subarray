class Solution:
    def maxSubArray(self, nums: List[int]) -> int:
        max_sum = nums[0]  # Initialize with first element
        curr_sum = nums[0]
        
        for num in nums[1:]:
            # Either start new subarray OR extend current
            curr_sum = max(num, curr_sum + num)
            max_sum = max(max_sum, curr_sum)
        
        return max_sum
