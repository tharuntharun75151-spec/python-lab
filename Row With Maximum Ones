class Solution:
    def rowAndMaximumOnes(self, mat: List[List[int]]) -> List[int]:
        m, n = len(mat), len(mat[0])
        max_ones = -1
        max_row = -1
        
        for i in range(m):
            ones_count = sum(mat[i])
            if ones_count > max_ones:
                max_ones = ones_count
                max_row = i
        
        return [max_row, max_ones]
